# Copy this file to .env for local development.
# Never commit real secrets.

# OCI OpenAI-compatible Responses API settings used by agent step2.
AGENT_LLM_MODEL_ID=openai.gpt-5.5
AGENT_LLM_API_KEY=replace-with-your-openai-compatible-api-key
AGENT_LLM_OCI_REGION=us-chicago-1

# Optional explicit endpoint. Leave empty to derive it from AGENT_LLM_OCI_REGION.
# AGENT_LLM_BASE_URL=https://inference.generativeai.us-chicago-1.oci.oraclecloud.com/openai/v1

# Existing local server and sample-agent settings.
A2A_SERVER_HOST=0.0.0.0
A2A_SERVER_PORT=8080
A2A_SERVER_PUBLIC_URL=http://localhost:8080
AGENT_LOG_LEVEL=INFO
AGENT_STEP_SLEEP_SECONDS=0
